# DATABASE_URL is required for Prisma (`migrate`, `seed`, `studio`).
#
# Prisma’s own CLI only auto-loads `.env` at the repo root — not `.env.local` (Next.js loads both).
# Options:
#   A) Copy this file to `.env` and set DATABASE_URL there, then `npx prisma migrate dev` works, or
#   B) Keep DATABASE_URL in `.env.local` only and always use the npm scripts (they load both files):
#        npm run db:migrate -- --name update-plans
#        npm run db:seed
#      (`package.json` prisma.seed also uses dotenv-cli so `npx prisma db seed` picks up `.env.local`.)
#
# Prefer loading env for any Prisma CLI command:
#   npm run prisma -- migrate dev --name my_migration
#   npm run prisma -- db seed
#
# If migrate reports P3015 for a migration that exists in the DB but not on disk, either restore that
# migration folder from git, or remove the orphan row (Neon SQL Editor) then migrate again:
#   DELETE FROM "_prisma_migrations" WHERE migration_name = 'MIGRATION_FOLDER_NAME';

DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
AUTH_SECRET="generate-a-random-secret-here"

# Local dev:
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel): set both to your canonical origin (no trailing slash).
# Wrong NEXTAUTH_URL can send users to localhost after sign-out or OAuth flows.
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ImageKit (file uploads: attachments, minutes, delegations, signatures, tenant logos)
IMAGEKIT_PUBLIC_KEY="your-public-key"
IMAGEKIT_PRIVATE_KEY="your-private-key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your-id"

# CCOS Live — LiveKit Cloud (or any LiveKit server; same variable names)
#
# Vercel: add ALL four variables for BOTH environments if you use both:
#   - Production → ccos.mahsumaah.sa (etc.)
#   - Preview → *.vercel.app (e.g. ccos-sigma.vercel.app) — Preview does NOT inherit Production secrets.
# Then redeploy after any env change.
#
# From Cloud dashboard: Project settings → Keys → WebSocket URL + API Key + Secret.
# WebSocket URL is usually: wss://<your-subdomain>.livekit.cloud
# Use the matching HTTPS origin for the server SDK (Room API), usually:
#   https://<your-subdomain>.livekit.cloud
LIVEKIT_WS_URL="wss://your-project.livekit.cloud"
LIVEKIT_HTTP_URL="https://your-project.livekit.cloud"
LIVEKIT_API_KEY="APIxxxxxxxx"
LIVEKIT_API_SECRET="secretxxxxxxxx"
#
# Webhooks: LiveKit Cloud → Project → Webhooks → add URL:
#   https://<your-ccos-domain>/api/livekit/webhook
# CCOS verifies the webhook with LIVEKIT_API_KEY + LIVEKIT_API_SECRET (same pair as above).
#
# (Self-hosted stack under infra/livekit/ is optional; it uses separate env files there.)

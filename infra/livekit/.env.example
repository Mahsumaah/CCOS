# LiveKit server
LIVEKIT_WS_URL=wss://live.mahsumaah.sa
LIVEKIT_HTTP_URL=https://live.mahsumaah.sa
LIVEKIT_API_KEY=lk_api_key
LIVEKIT_API_SECRET=lk_api_secret
LIVEKIT_WEBHOOK_KEY=lk_webhook_key
LIVEKIT_WEBHOOK_URL=https://ccos.mahsumaah.sa/api/livekit/webhook

# Egress recording storage
LIVEKIT_REDIS_URL=redis://127.0.0.1:6379
LIVEKIT_S3_ACCESS_KEY=replace
LIVEKIT_S3_SECRET=replace
LIVEKIT_S3_ENDPOINT=s3.mahsumaah.sa
LIVEKIT_S3_REGION=me-central-1
LIVEKIT_S3_BUCKET=ccos-live-artifacts

# TURN
TURN_REALM=live.mahsumaah.sa
TURN_SHARED_SECRET=replace

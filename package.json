{
  "name": "ccos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:migrate": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- prisma migrate dev",
    "db:deploy": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- prisma migrate deploy",
    "db:push": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- prisma db push",
    "db:seed": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- prisma db seed",
    "db:studio": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- prisma studio",
    "db:validate": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- prisma validate",
    "prisma": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- prisma"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@mdxeditor/editor": "^3.52.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-toast": "^1.2.15",
    "@tabler/icons-react": "^3.36.0",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "embla-carousel-react": "^8.6.0",
    "eslint-plugin-better-tailwindcss": "^3.8.0",
    "imagekit": "^6.0.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.503.0",
    "next": "16.1.0",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "radix-ui": "latest",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.68.0",
    "react-resizable-panels": "^4.0.10",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.27",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "node ./node_modules/dotenv-cli/cli.js -e .env -e .env.local -- npx tsx prisma/seed.ts"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    }
  }
}

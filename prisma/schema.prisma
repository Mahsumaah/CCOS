generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ TENANT ============

model Tenant {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logo           String?
  plan           Plan      @default(TRIAL)
  trialEndsAt    DateTime?
  /// Default locale for org communications / future emails
  defaultLocale  String    @default("ar")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users    BoardUser[]
  meetings Meeting[]
  liveSessions        LiveSession[]
  liveParticipantSessions LiveParticipantSession[]
  liveVotes           LiveVote[]
  liveVoteBallots     LiveVoteBallot[]
  liveDecisionEvents  LiveDecisionEvent[]
  meetingArtifacts    MeetingArtifact[]
  auditLogs           AuditLog[]
  transcriptSegments  TranscriptSegment[]
}

enum Plan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============ BOARD USER ============

model BoardUser {
  id                   String    @id @default(cuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
  email                String
  password             String?
  passwordSetupToken   String?   @unique
  passwordSetupExpires DateTime?
  name                 String
  role                 BoardRole @default(MEMBER)
  avatar               String?
  positionCode         String?
  position             OrganizationalPosition? @relation(fields: [positionCode], references: [code])
  isActive             Boolean   @default(true)

  // Fine-grained permissions
  permCreateMeetings  Boolean @default(false)
  permEditMeetings    Boolean @default(false)
  permManageMeetings  Boolean @default(false)
  permCreateVotes     Boolean @default(false)
  permCastVotes       Boolean @default(true)
  permCreateDecisions Boolean @default(false)
  permEditDecisions   Boolean @default(false)
  permFinalizeMinutes Boolean @default(false)
  permManagePositions Boolean @default(false)
  permManageUsers     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdMeetings     Meeting[]             @relation("CreatedBy")
  invitations         MeetingInvitation[]
  delegationsFrom     MeetingDelegation[]   @relation("DelegatedFrom")
  delegationsTo       MeetingDelegation[]   @relation("DelegatedTo")
  ballots             VoteBallot[]          @relation("VotedBy")
  proxiedBallots      VoteBallot[]          @relation("ProxiedBy")
  createdVotes        Vote[]
  createdDecisions    Decision[]            @relation("DecisionCreatedBy")
  approvedDecisions   Decision[]            @relation("DecisionApprovedBy")
  ownedDecisions      Decision[]            @relation("DecisionOwnedBy")
  signatures          MinutesSignature[]
  notifications       BoardNotification[]
  uploadedAttachments MeetingAttachment[]
  startedLiveSessions LiveSession[]           @relation("LiveSessionStartedBy")
  endedLiveSessions   LiveSession[]           @relation("LiveSessionEndedBy")
  liveParticipantSessions LiveParticipantSession[]
  startedLiveVotes    LiveVote[]              @relation("LiveVoteOpenedBy")
  closedLiveVotes     LiveVote[]              @relation("LiveVoteClosedBy")
  liveVoteBallots     LiveVoteBallot[]
  recordedLiveDecisions LiveDecisionEvent[]   @relation("LiveDecisionRecordedBy")
  proposedLiveDecisions LiveDecisionEvent[]   @relation("LiveDecisionProposedBy")
  updatedLiveDecisions  LiveDecisionEvent[]   @relation("LiveDecisionUpdatedBy")
  ownedLiveDecisions    LiveDecisionEvent[]   @relation("LiveDecisionOwnedBy")
  meetingArtifacts    MeetingArtifact[]       @relation("ArtifactCreatedBy")
  auditLogs           AuditLog[]              @relation("AuditActor")

  @@unique([tenantId, email])
}

enum BoardRole {
  CHAIR
  VICE_CHAIR_1
  VICE_CHAIR_2
  VICE_CHAIR_3
  VICE_CHAIR_4
  MEMBER
  SECRETARY_GENERAL
  ASSISTANT_SECRETARY_GENERAL
  SUPERVISOR
  MINUTES_CLERK
  TREASURER
  VIEWER
}

// ============ MEETING ============

model Meeting {
  id                     String                @id @default(cuid())
  tenantId               String
  tenant                 Tenant                @relation(fields: [tenantId], references: [id])
  title                  String
  type                   MeetingType           @default(BOARD)
  customMeetingType      String?
  objectives             String?
  scheduledAt            DateTime
  durationMin            Int                   @default(60)
  location               String?
  schedulingMode         MeetingSchedulingMode @default(SCHEDULED)
  status                 MeetingStatus         @default(SCHEDULED)
  startedAt              DateTime?
  endedAt                DateTime?
  preMeetingInviteSentAt DateTime?
  createdById            String
  createdBy              BoardUser             @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  agenda          MeetingAgendaItem[]
  attachments     MeetingAttachment[]
  invitations     MeetingInvitation[]
  delegations     MeetingDelegation[]
  votes           Vote[]
  decisions       Decision[]
  minutes         Minutes?
  notifications   BoardNotification[]
  liveSessions           LiveSession[]
  liveParticipantSessions LiveParticipantSession[]
  liveVotes              LiveVote[]
  liveVoteBallots        LiveVoteBallot[]
  liveDecisionEvents     LiveDecisionEvent[]
  artifacts              MeetingArtifact[]
  auditLogs              AuditLog[]
  transcriptSegments     TranscriptSegment[]
}

enum LiveSessionStatus {
  IDLE
  LIVE
  ENDED
}

enum LiveRecordingStatus {
  NOT_STARTED
  RECORDING
  COMPLETED
  FAILED
}

enum MeetingLiveRole {
  CHAIR
  VICE_CHAIR
  SECRETARY
  DECISION_RECORDER
  VOTING_MEMBER
  NON_VOTING_MEMBER
  OBSERVER
  GUEST
  SYSTEM_ADMIN
}

enum LiveVoteVisibility {
  PUBLIC
  SECRET
}

enum LiveVoteRule {
  MAJORITY
  QUORUM_GATED
  ROLE_WEIGHTED
}

enum LiveVoteChoice {
  YES
  NO
  ABSTAIN
}

enum LiveDecisionStatus {
  DRAFT
  APPROVED
  REJECTED
  IN_REVIEW
}

enum ArtifactType {
  RECORDING
  TRANSCRIPT
  AI_MINUTES_DRAFT
  FINAL_MINUTES
  SIGNED_MINUTES
}

enum AuditAction {
  LIVE_SESSION_OPENED
  LIVE_SESSION_CLOSED
  PARTICIPANT_JOINED
  PARTICIPANT_LEFT
  PARTICIPANT_REJOINED
  PARTICIPANT_RAISED_HAND
  PARTICIPANT_MUTED
  PARTICIPANT_REMOVED
  SCREEN_SHARE_STARTED
  SCREEN_SHARE_STOPPED
  LIVE_VOTE_OPENED
  LIVE_VOTE_CAST
  LIVE_VOTE_CLOSED
  LIVE_DECISION_CREATED
  LIVE_DECISION_UPDATED
  LIVE_DECISION_APPROVED
  ARTIFACT_CREATED
  MINUTES_SIGNED
}

model LiveSession {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  meetingId     String
  meeting       Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  roomName      String
  status        LiveSessionStatus   @default(IDLE)
  startedAt     DateTime?
  endedAt       DateTime?
  startedById   String?
  startedBy     BoardUser?          @relation("LiveSessionStartedBy", fields: [startedById], references: [id])
  endedById     String?
  endedBy       BoardUser?          @relation("LiveSessionEndedBy", fields: [endedById], references: [id])
  recordingStatus LiveRecordingStatus @default(NOT_STARTED)
  recordingUrl  String?
  recordingError String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  participants       LiveParticipantSession[]
  liveVotes          LiveVote[]
  liveDecisionEvents LiveDecisionEvent[]
  artifacts          MeetingArtifact[]
  auditLogs          AuditLog[]
  transcriptSegments TranscriptSegment[]

  @@unique([meetingId, roomName])
  @@index([tenantId, meetingId, createdAt])
}

model LiveParticipantSession {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  meetingId       String
  meeting         Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  liveSessionId   String
  liveSession     LiveSession  @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  userId          String
  user            BoardUser    @relation(fields: [userId], references: [id])
  participantSid  String?
  role            MeetingLiveRole
  joinedAt        DateTime     @default(now())
  leftAt          DateTime?
  reconnectCount  Int          @default(0)
  raisedHandAt    DateTime?
  mutedByChairAt  DateTime?
  removedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([tenantId, meetingId, joinedAt])
  @@index([liveSessionId, joinedAt])
}

model LiveVote {
  id            String             @id @default(cuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  meetingId     String
  meeting       Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  liveSessionId String?
  liveSession   LiveSession?       @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  agendaItemId  String?
  agendaItem    MeetingAgendaItem? @relation(fields: [agendaItemId], references: [id])
  title         String
  question      String
  visibility    LiveVoteVisibility @default(PUBLIC)
  rule          LiveVoteRule       @default(MAJORITY)
  quorumRequired Boolean           @default(false)
  allowedRoles  Json?
  isOpen        Boolean            @default(true)
  openedAt      DateTime           @default(now())
  closedAt      DateTime?
  openedById    String
  openedBy      BoardUser          @relation("LiveVoteOpenedBy", fields: [openedById], references: [id])
  closedById    String?
  closedBy      BoardUser?         @relation("LiveVoteClosedBy", fields: [closedById], references: [id])
  resultJson    Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  ballots       LiveVoteBallot[]
  auditLogs     AuditLog[]

  @@index([tenantId, meetingId, openedAt])
  @@index([liveSessionId, openedAt])
}

model LiveVoteBallot {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  meetingId     String
  meeting       Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  liveVoteId    String
  liveVote      LiveVote       @relation(fields: [liveVoteId], references: [id], onDelete: Cascade)
  userId        String
  user          BoardUser      @relation(fields: [userId], references: [id])
  choice        LiveVoteChoice
  isDelegated   Boolean        @default(false)
  castAt        DateTime       @default(now())
  metadataJson  Json?

  @@unique([liveVoteId, userId])
  @@index([tenantId, meetingId, castAt])
}

model LiveDecisionEvent {
  id              String             @id @default(cuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  meetingId       String
  meeting         Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  liveSessionId   String?
  liveSession     LiveSession?       @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  agendaItemId    String?
  agendaItem      MeetingAgendaItem? @relation(fields: [agendaItemId], references: [id])
  decisionText    String
  status          LiveDecisionStatus @default(DRAFT)
  proposedById    String?
  proposedBy      BoardUser?         @relation("LiveDecisionProposedBy", fields: [proposedById], references: [id])
  recordedById    String
  recordedBy      BoardUser          @relation("LiveDecisionRecordedBy", fields: [recordedById], references: [id])
  ownerId         String?
  owner           BoardUser?         @relation("LiveDecisionOwnedBy", fields: [ownerId], references: [id])
  dueDate         DateTime?
  notes           String?
  requiresVote    Boolean            @default(false)
  approved        Boolean            @default(false)
  approvedAt      DateTime?
  updatedById     String?
  updatedBy       BoardUser?         @relation("LiveDecisionUpdatedBy", fields: [updatedById], references: [id])
  eventAt         DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  auditLogs       AuditLog[]

  @@index([tenantId, meetingId, eventAt])
  @@index([liveSessionId, eventAt])
}

model MeetingArtifact {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  meetingId       String
  meeting         Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  liveSessionId   String?
  liveSession     LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  type            ArtifactType
  url             String
  name            String
  mime            String?
  size            Int?
  source          String?
  createdById     String?
  createdBy       BoardUser?   @relation("ArtifactCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())

  @@index([tenantId, meetingId, createdAt])
}

model TranscriptSegment {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  meetingId       String
  meeting         Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  liveSessionId   String?
  liveSession     LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  speakerName     String?
  speakerUserId   String?
  language        String?
  text            String
  startedAtMs     Int?
  endedAtMs       Int?
  confidence      Float?
  metadataJson    Json?
  createdAt       DateTime     @default(now())

  @@index([tenantId, meetingId, createdAt])
}

model AuditLog {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  meetingId       String?
  meeting         Meeting?     @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  liveSessionId   String?
  liveSession     LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  liveVoteId      String?
  liveVote        LiveVote?    @relation(fields: [liveVoteId], references: [id], onDelete: SetNull)
  liveDecisionEventId String?
  liveDecisionEvent LiveDecisionEvent? @relation(fields: [liveDecisionEventId], references: [id], onDelete: SetNull)
  actorId         String?
  actor           BoardUser?   @relation("AuditActor", fields: [actorId], references: [id])
  action          AuditAction
  targetType      String
  targetId        String?
  payloadJson     Json?
  createdAt       DateTime     @default(now())

  @@index([tenantId, meetingId, createdAt])
  @@index([tenantId, action, createdAt])
}

enum MeetingType {
  BOARD
  EMERGENCY
  ASSEMBLY
  EXECUTIVE_COMMITTEE
  TECHNICAL_COMMITTEE
  FINANCIAL_COMMITTEE
  STRATEGIC
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  ARCHIVED
  CANCELLED
}

enum MeetingSchedulingMode {
  INSTANT
  SCHEDULED
}

// ============ AGENDA ============

model MeetingAgendaItem {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  order     Int
  titleAr   String
  titleEn   String?
  notes     String?

  attachments MeetingAttachment[]
  votes       Vote[]
  decisions   Decision[]
  liveVotes   LiveVote[]
  liveDecisionEvents LiveDecisionEvent[]
}

// ============ ATTACHMENT ============

model MeetingAttachment {
  id             String             @id @default(cuid())
  meetingId      String
  meeting        Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  agendaItemId   String?
  agendaItem     MeetingAgendaItem? @relation(fields: [agendaItemId], references: [id])
  url            String
  name           String
  mime           String?
  size           Int?
  uploadedById   String
  uploadedBy     BoardUser          @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime           @default(now())
}

// ============ INVITATION ============

model MeetingInvitation {
  id                      String           @id @default(cuid())
  meetingId               String
  meeting                 Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId                  String
  user                    BoardUser        @relation(fields: [userId], references: [id])
  role                    BoardRole
  status                  InvitationStatus @default(PENDING)
  respondedAt             DateTime?
  attendanceCheckedInAt DateTime?
  notes                   String?

  @@unique([meetingId, userId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

// ============ DELEGATION ============

model MeetingDelegation {
  id          String          @id @default(cuid())
  meetingId   String
  meeting     Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  fromUserId  String
  fromUser    BoardUser       @relation("DelegatedFrom", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      BoardUser       @relation("DelegatedTo", fields: [toUserId], references: [id])
  scope       DelegationScope @default(ATTENDANCE_ONLY)
  authDocUrl  String?
  authDocName String?
  authDocMime String?
  authDocSize Int?
  revokedAt   DateTime?
  createdAt   DateTime        @default(now())
}

enum DelegationScope {
  ATTENDANCE_ONLY
  ATTENDANCE_AND_VOTING
}

// ============ VOTE ============

model Vote {
  id           String             @id @default(cuid())
  meetingId    String
  meeting      Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  agendaItemId String?
  agendaItem   MeetingAgendaItem? @relation(fields: [agendaItemId], references: [id])
  question     String
  isOpen       Boolean            @default(true)
  openedAt     DateTime           @default(now())
  closedAt     DateTime?
  createdById  String
  createdBy    BoardUser          @relation(fields: [createdById], references: [id])

  ballots VoteBallot[]
}

model VoteBallot {
  id        String     @id @default(cuid())
  voteId    String
  vote      Vote       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  userId    String
  user      BoardUser  @relation("VotedBy", fields: [userId], references: [id])
  castById  String?
  castBy    BoardUser? @relation("ProxiedBy", fields: [castById], references: [id])
  choice    VoteChoice
  createdAt DateTime   @default(now())

  @@unique([voteId, userId])
}

enum VoteChoice {
  APPROVE
  REJECT
  ABSTAIN
}

// ============ DECISION ============

model Decision {
  id           String             @id @default(cuid())
  meetingId    String
  meeting      Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  agendaItemId String?
  agendaItem   MeetingAgendaItem? @relation(fields: [agendaItemId], references: [id])
  textAr       String
  textEn       String?
  status       DecisionStatus     @default(OPEN)
  ownerId      String?
  owner        BoardUser?         @relation("DecisionOwnedBy", fields: [ownerId], references: [id])
  dueDate      DateTime?
  createdById  String
  createdBy    BoardUser          @relation("DecisionCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   BoardUser?         @relation("DecisionApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

enum DecisionStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

// ============ MINUTES ============

model Minutes {
  id                  String    @id @default(cuid())
  meetingId           String    @unique
  meeting             Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  contentJson         Json?
  contentHtml         String
  generatedAt         DateTime  @default(now())
  finalizedAt         DateTime?
  finalizedById       String?
  adoptedDocumentUrl   String?
  adoptedDocumentName  String?
  adoptedDocumentMime  String?
  adoptedDocumentSize  Int?
  adoptedById         String?
  adoptedAt           DateTime?
  attendeesNotifiedAt DateTime?

  signatures MinutesSignature[]
}

model MinutesSignature {
  id                  String    @id @default(cuid())
  minutesId           String
  minutes             Minutes   @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  userId              String
  user                BoardUser @relation(fields: [userId], references: [id])
  signatureImageUrl   String?
  typedName           String?
  signedAt            DateTime  @default(now())
  ip                  String?
  userAgent           String?
  hash                String?

  @@unique([minutesId, userId])
}

// ============ NOTIFICATION ============

model BoardNotification {
  id        String    @id @default(cuid())
  userId    String
  user      BoardUser @relation(fields: [userId], references: [id])
  meetingId String?
  meeting   Meeting?  @relation(fields: [meetingId], references: [id])
  type      String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

// ============ QUORUM ============

model MeetingTypeQuorumPolicy {
  meetingType          MeetingType    @id
  quorumRequired       Boolean        @default(true)
  ruleMode             QuorumRuleMode @default(ABSOLUTE_MAJORITY)
  minAttendancePercent Int?
  optionsJson          Json?
  updatedAt            DateTime       @updatedAt
}

enum QuorumRuleMode {
  ABSOLUTE_MAJORITY
  TWO_THIRDS
  MIN_PERCENT
}

// ============ POSITIONS ============

model OrganizationalPosition {
  code      String           @id
  labelAr   String
  labelEn   String?
  level     Int              @default(0)
  category  PositionCategory @default(BOARD)
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)

  users BoardUser[]
}

enum PositionCategory {
  BOARD
  EXECUTIVE
  TECHNICAL
  ADMINISTRATIVE
}
